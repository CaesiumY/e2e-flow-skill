# .github/workflows/playwright.yml
# Generated by e2e-flow skill (Phase 4).
# Dynamic Shard 기반 E2E 워크플로우.
# - 테스트 개수에 비례한 shard 자동 생성
# - 빌드 1회 + artifact 공유
# - 실패 시 shard 리포트를 하나의 HTML로 병합

name: E2E Tests

on:
  pull_request:
    types: [labeled]   # 'e2e' 또는 'release' 라벨 추가 시 트리거
  workflow_dispatch:
  # 야간 스케줄을 원하면 주석 해제 (KST 오전 7시 = UTC 22시)
  # schedule:
  #   - cron: '0 22 * * *'

concurrency:
  group: e2e-${{ github.ref }}
  cancel-in-progress: true

jobs:
  # ---------------------------------------------------------------
  # 라벨 필터 — labeled 트리거에서 e2e/release만 통과
  # ---------------------------------------------------------------
  filter:
    if: |
      github.event_name != 'pull_request' ||
      github.event.label.name == 'e2e' ||
      github.event.label.name == 'release'
    runs-on: ubuntu-latest
    steps:
      - run: echo "Passed label filter"

  # ---------------------------------------------------------------
  # 빌드 1회 — 다른 job들이 artifact로 받아 쓴다
  # ---------------------------------------------------------------
  build:
    needs: filter
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        if: ${{ '{{PACKAGE_MANAGER}}' == 'pnpm' }}
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_CMD}}
      - run: {{BUILD_CMD}}
      - uses: actions/upload-artifact@v4
        with:
          name: tests-build
          path: |
            .next
            dist
            build
          if-no-files-found: ignore
          retention-days: 1

  # ---------------------------------------------------------------
  # 테스트 개수 측정 → shard 매트릭스 생성 (15개당 1 shard)
  # ---------------------------------------------------------------
  generate-shards-matrix:
    needs: filter
    runs-on: ubuntu-latest
    outputs:
      matrix: ${{ steps.set-matrix.outputs.matrix }}
      shard-count: ${{ steps.set-matrix.outputs.shard-count }}
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        if: ${{ '{{PACKAGE_MANAGER}}' == 'pnpm' }}
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_CMD}}
      - run: {{PACKAGE_MANAGER}} exec playwright install --with-deps chromium

      - name: Calculate Shards
        id: set-matrix
        run: |
          TOTAL_TESTS=$({{PACKAGE_MANAGER}} test:e2e --list 2>/dev/null | grep -E '^\s*Total:' | awk '{print $2}')
          if [ -z "$TOTAL_TESTS" ] || [ "$TOTAL_TESTS" -eq 0 ]; then
            TOTAL_TESTS=1
          fi
          SHARD_COUNT=$(( (TOTAL_TESTS + 14) / 15 ))
          MATRIX=$(jq -cn --argjson count "$SHARD_COUNT" \
            '[range(1; $count + 1) | {"shard-index": ., "total-shards": $count}]')
          echo "Total tests: $TOTAL_TESTS, shards: $SHARD_COUNT"
          echo "matrix=$MATRIX" >> "$GITHUB_OUTPUT"
          echo "shard-count=$SHARD_COUNT" >> "$GITHUB_OUTPUT"

  # ---------------------------------------------------------------
  # 병렬 E2E 실행
  # ---------------------------------------------------------------
  e2e-test:
    needs: [build, generate-shards-matrix]
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        include: ${{ fromJSON(needs.generate-shards-matrix.outputs.matrix) }}
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        if: ${{ '{{PACKAGE_MANAGER}}' == 'pnpm' }}
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_CMD}}
      - run: {{PACKAGE_MANAGER}} exec playwright install --with-deps chromium

      - uses: actions/download-artifact@v4
        with:
          name: tests-build
          path: .

      - name: Run Playwright Tests
        run: |
          {{PACKAGE_MANAGER}} test:e2e \
            --shard=${{ matrix.shard-index }}/${{ matrix.total-shards }} \
            --reporter=blob

      - name: Upload Report Blob
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: test-report-${{ matrix.shard-index }}
          path: blob-report
          retention-days: 1

  # ---------------------------------------------------------------
  # 실패 시 shard 리포트 병합 → 단일 HTML
  # ---------------------------------------------------------------
  merge-reports:
    if: ${{ always() && cancelled() == false && needs.e2e-test.result == 'failure' }}
    needs: [e2e-test]
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: pnpm/action-setup@v4
        if: ${{ '{{PACKAGE_MANAGER}}' == 'pnpm' }}
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NODE_VERSION}}'
          cache: '{{PACKAGE_MANAGER}}'
      - run: {{INSTALL_CMD}}

      - uses: actions/download-artifact@v4
        with:
          pattern: test-report-*
          merge-multiple: true
          path: blob-reports

      - run: {{PACKAGE_MANAGER}} exec playwright merge-reports --reporter html ./blob-reports

      - uses: actions/upload-artifact@v4
        with:
          name: e2e-html-report
          path: playwright-report
          retention-days: 7
