import type { Page, Route } from '@playwright/test';

export interface MockHandler {
  /** url + method를 보고 매칭 여부 반환. */
  match: (url: string, method: string) => boolean;
  responseBody: unknown;
  status?: number;
  headers?: Record<string, string>;
}

/** 핸들러 배열을 등록한다. 매칭되지 않은 요청은 그대로 통과. */
export async function apiMockHandlers(page: Page, handlers: MockHandler[]): Promise<void> {
  await page.route('**/*', async (route: Route) => {
    const request = route.request();
    const matched = handlers.find((h) => h.match(request.url(), request.method()));
    if (matched) {
      await route.fulfill({
        status: matched.status ?? 200,
        contentType: 'application/json',
        headers: matched.headers,
        body: JSON.stringify(matched.responseBody),
      });
      return;
    }
    await route.continue();
  });
}

/** path suffix + method 기반 매처 헬퍼. */
export function signatureMatch(signature: { path: string; method: string }) {
  const targetMethod = signature.method.toUpperCase();
  return (url: string, method: string) => {
    if (method.toUpperCase() !== targetMethod) return false;
    try {
      return new URL(url).pathname.endsWith(signature.path);
    } catch {
      return false;
    }
  };
}

/** 정규식 기반 매처 헬퍼. */
export function patternMatch(pattern: RegExp, method?: string) {
  const targetMethod = method?.toUpperCase();
  return (url: string, requestMethod: string) => {
    if (targetMethod && requestMethod.toUpperCase() !== targetMethod) return false;
    return pattern.test(url);
  };
}
