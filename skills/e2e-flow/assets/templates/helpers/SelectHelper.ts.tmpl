// e2e/helpers/SelectHelper.ts
// Generated by e2e-flow skill (Phase 1). Maps to Select/Combobox in your design system.
import { expect, type Page, type Locator } from '@playwright/test';

export class SelectHelper {
  constructor(private readonly page: Page) {}

  /** label로 식별된 select에서 옵션 선택. */
  async selectByLabel(
    label: string,
    optionText: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    const trigger = root.getByLabel(label);
    await trigger.click();
    // option 메뉴는 portal로 렌더링되는 경우가 흔해 page 전역에서 검색
    await this.page.getByRole('option', { name: optionText }).click();
  }

  /** 첫 옵션 선택 (값 신경 안 쓰고 통과만 시킬 때). */
  async selectFirstOption(
    label: string,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    const trigger = root.getByLabel(label);
    await trigger.click();
    await this.page.getByRole('option').first().click();
  }

  /** 현재 선택값 검증. */
  async expectSelected(
    label: string,
    expectedText: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    await expect(root.getByLabel(label)).toHaveText(expectedText);
  }
}
