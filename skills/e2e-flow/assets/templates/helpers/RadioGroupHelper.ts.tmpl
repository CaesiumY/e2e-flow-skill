// Generated by e2e-flow skill (Phase 1). Maps to RadioGroup in your design system.
import { expect, type Page, type Locator } from '@playwright/test';

export class RadioGroupHelper {
  constructor(private readonly page: Page) {}

  /** 그룹 안에서 옵션 선택. "결제 방법으로 신용카드 선택" 자연어에 매핑. */
  async selectByLabel(
    groupLabel: string,
    optionLabel: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    // shadcn/ui 등은 role="radiogroup"; 표준 <fieldset>은 기본 role이 group이므로 둘 다 탐색.
    const group = root
      .getByRole('radiogroup', { name: groupLabel })
      .or(root.getByRole('group', { name: groupLabel }));
    await expect(group).toBeVisible();
    await group.getByRole('radio', { name: optionLabel }).check();
  }

  /** 현재 선택된 옵션 검증. */
  async expectSelected(
    groupLabel: string,
    expectedOption: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    const group = root
      .getByRole('radiogroup', { name: groupLabel })
      .or(root.getByRole('group', { name: groupLabel }));
    await expect(group.getByRole('radio', { name: expectedOption })).toBeChecked();
  }
}
