// e2e/helpers/NavigationHelper.ts
// Generated by e2e-flow skill (Phase 1). Maps to Tabs/Breadcrumb/routing.
import { expect, type Page, type Locator } from '@playwright/test';

export class NavigationHelper {
  constructor(private readonly page: Page) {}

  /** 탭 클릭. */
  async clickTab(
    tabName: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    await root.getByRole('tab', { name: tabName }).click();
  }

  /** URL이 패턴과 매칭되는지 검증. page 전역 상태라 within 옵션 없음. */
  async expectUrlMatches(pattern: string | RegExp): Promise<void> {
    await expect(this.page).toHaveURL(pattern);
  }

  /** 현재 활성 탭 검증. */
  async expectActiveTab(
    tabName: string | RegExp,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    await expect(
      root.getByRole('tab', { name: tabName, selected: true }),
    ).toBeVisible();
  }

  /** 브레드크럼 항목 순서대로 검증. */
  async expectBreadcrumb(
    items: string[],
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    const breadcrumb = root.getByRole('navigation', { name: /breadcrumb|경로/i });
    for (const item of items) {
      await expect(breadcrumb.getByText(item)).toBeVisible();
    }
  }
}
