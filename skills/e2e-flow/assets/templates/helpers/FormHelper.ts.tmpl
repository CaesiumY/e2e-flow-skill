// e2e/helpers/FormHelper.ts
// Generated by e2e-flow skill (Phase 1). Maps to Form/Input in your design system.
import { expect, type Page, type Locator } from '@playwright/test';

export class FormHelper {
  constructor(private readonly page: Page) {}

  /** label-value 쌍을 받아 차례로 입력. */
  async fillFields(
    fields: Record<string, string>,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    for (const [label, value] of Object.entries(fields)) {
      const field = root.getByLabel(label);
      await expect(field).toBeEditable();
      await field.fill(value);
    }
  }

  /** 제출 버튼 클릭. label 기본값은 디자인 시스템에 맞춰 조정. */
  async submit(
    label: string | RegExp = '저장',
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    await root.getByRole('button', { name: label }).click();
  }

  /** 폼 에러 메시지 검증 — 개별 locator로 (Strict Mode 안전). */
  async expectErrors(
    messages: string[],
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    for (const msg of messages) {
      await expect(root.getByText(msg)).toBeVisible();
    }
  }

  /** 특정 필드의 편집 가능 여부 검증. */
  async expectFieldEditable(
    label: string,
    editable = true,
    opts?: { within?: Locator },
  ): Promise<void> {
    const root = opts?.within ?? this.page;
    const field = root.getByLabel(label);
    if (editable) await expect(field).toBeEditable();
    else await expect(field).toBeDisabled();
  }
}
