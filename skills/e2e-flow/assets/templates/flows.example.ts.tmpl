// flow는 Helper를 받아 행동을 구현한다. 저수준 Playwright API 직접 사용 금지.
import { expect, type Page } from '@playwright/test';
import type { NavigationHelper } from '../../../helpers/NavigationHelper';

interface LandingContext {
  page: Page;
  navigation: NavigationHelper;
}

export async function 랜딩_페이지_확인_플로우({ page, navigation }: LandingContext) {
  // URL이 루트인지
  await navigation.expectUrlMatches(/\/$/);
  // 최소한의 시멘틱 확인 — 페이지에 main 영역이 있어야 한다
  await expect(page.getByRole('main')).toBeVisible();
}
